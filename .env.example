# ============================================================
# WC2026 Tracker — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to GitHub.
# Add these same values to Vercel → Project → Settings → Environment Variables.

# ── Supabase ──────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Your Project → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key_here

# ── App ───────────────────────────────────────────────────────
# Your Vercel deployment URL (used for OAuth redirects)
# Example: https://wc2026.vercel.app
APP_URL=https://YOUR_APP.vercel.app
